{
  "spec_version": "2.0",
  "id": "ipfs",
  "name": "IPFS",
  "description": "Search IPFS-hosted datasets via ipfs-search.com API.",
  "source": "ipfs",
  "tags": [
    "decentralized",
    "files"
  ],
  "routing_hints": [
    "ipfs",
    "content addressed",
    "decentralized files"
  ],
  "enabled": true,
  "capabilities": {
    "search": true,
    "lookup": false,
    "download": false,
    "schema_probe": false,
    "sample_preview": false,
    "license_lookup": false
  },
  "governance": {
    "trust_tier": "community",
    "provenance_hint": "IPFS content identifiers and public gateways",
    "compliance_hint": "verify content provenance and legal usage before retrieval"
  },
  "provider": {
    "kind": "http_search",
    "base_url": "https://api.ipfs-search.com",
    "operations": {
      "search": {
        "path": "/v1/search",
        "method": "GET",
        "query_param": "q",
        "limit_param": "page_size",
        "static_params": {
          "type": "file"
        },
        "result_path": "hits"
      }
    },
    "item_mapping": {
      "title": "title",
      "description": "description",
      "id": "hash",
      "size_bytes": "size",
      "created_at": "first-seen"
    }
  }
}
